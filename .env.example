# Ditto V5 — API keys
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# ── Rocket League ──────────────────────────────────────────────────
# Get from: https://ballchasing.com → Account → API key
BALLCHASING_TOKEN=your_ballchasing_token_here

# ── CS:GO / CS2 ────────────────────────────────────────────────────
# Get from: https://developers.faceit.com → My Apps → Create App → API Key
FACEIT_API_KEY=your_faceit_api_key_here

# ── LLM Judge ──────────────────────────────────────────────────────
# Required for real evaluation (not needed for --dry-run)
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OpenRouter (v5.1 cross-model run) ──────────────────────────────
# OR rate-limits per API key. v5.1 splits its 9 OR models 5/4 across
# two keys to roughly halve aggregate OR wall time. Both keys can
# point at the same OpenRouter account; create them under
# https://openrouter.ai → Keys. The 5/4 split is configured in
# v5_1_design/provider_pinning.json under each model's `key_env`.
# Models on OPENROUTER_API_KEY:    glm-4.7, llama-3.3-70b, mimo-v2-pro,
#                                   qwen3.6-plus, grok-4-fast
# Models on OPENROUTER_API_KEY_2:  qwen3.6-max-preview, grok-4.20,
#                                   glm-5, mimo-v2.5-pro
OPENROUTER_API_KEY=your_openrouter_key_1_here
OPENROUTER_API_KEY_2=your_openrouter_key_2_here
